**TER CERTEZA DE DELETAR POSSÍVEIS TABELAS JÁ EXISTENTES COM O MESMO NOME

drop table beneficiario cascade constraint;
drop table dentista cascade constraint;


create table beneficiario (ID number generated by default as identity,
                           NOME varchar2(100),
                           IDADE number(3),
                           CPF varchar2(11),
                           DT_NASC Date,
                           EMAIL varchar2(255),
                           TELEFONE varchar2(15),
                           ENDERECO varchar2(255));

create table dentista (CRO number(38) primary key,
                       NOME varchar2(100),
                       IDADE number(3),
                       CPF varchar2(11),
                       DT_NASC Date,
                       EMAIL varchar2(255),
                       TELEFONE varchar2(15),
                       ENDERECO varchar2(255));