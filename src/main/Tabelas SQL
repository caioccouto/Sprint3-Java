**TER CERTEZA DE DELETAR POSSÍVEIS TABELAS JÁ EXISTENTES COM O MESMO NOME

drop table beneficiario cascade constraint;
drop table dentista cascade constraint;
drop table doador cascade constraint;
drop table doacao cascade constraint;


create table BENEFICIARIO (
    ID        number generated by default as identity,
    NOME      varchar2(100),
    IDADE     number(3),
    CPF       varchar2(11),
    DT_NASC   date,
    EMAIL     varchar2(255),
    TELEFONE  varchar2(15),
    ENDERECO  varchar2(255),
    constraint PK_BENEFICIARIO primary key (ID)
);

create table DENTISTA (
    CRO       number(38) constraint PK_DENTISTA primary key,
    NOME      varchar2(100),
    IDADE     number(3),
    CPF       varchar2(11),
    DT_NASC   date,
    EMAIL     varchar2(255),
    TELEFONE  varchar2(15),
    ENDERECO  varchar2(255)
);

create table DOADOR (
    ID           number generated by default as identity,
    NOME         varchar2(100)  not null,
    IDADE        number(3),
    CPF          varchar2(11),
    DT_NASC      date,
    EMAIL        varchar2(255),
    TELEFONE     varchar2(15),
    ENDERECO     varchar2(255),
    TIPO_PESSOA  varchar2(2)    not null,
    CNPJ         varchar2(14),
    constraint PK_DOADOR primary key (ID),
    constraint CK_TIPO_PESSOA check (TIPO_PESSOA in ('PF', 'PJ'))
);

create table DOACAO (
    ID          number generated by default as identity,
    ID_DOADOR   number          not null,
    VALOR       number(10, 2)   not null,
    DT_DOACAO   date            not null,
    DESCRICAO   varchar2(255),
    constraint PK_DOACAO  primary key (ID),
    constraint FK_DOACAO_DOADOR foreign key (ID_DOADOR) references DOADOR(ID),
    constraint CK_VALOR_POSITIVO check (VALOR > 0)
);

create table VOLUNTARIO (
    CRO       number(38) constraint PK_VOLUNTARIO primary key,
    NOME      varchar2(100),
    IDADE     number(3),
    CPF       varchar2(11),
    DT_NASC   date,
    EMAIL     varchar2(255),
    TELEFONE  varchar2(15),
    ENDERECO  varchar2(255),
    DT_CADASTRO date
);